# ============================================================
# 车辆信息接口
# ============================================================
# 从 Postman 复制完整 GET URL（含 sign / timestamp），再单独填 Token
NIO_VEHICLE_API_URL=https://icar.nio.com/api/2/rvs/vehicle/your_vehicle_id/status?field=exterior&field=soc&field=position&app_ver=6.6.0&timestamp=...&device_id=...&app_id=10002&region=cn&lang=zh-CN&sign=...
NIO_VEHICLE_ACCESS_TOKEN=

# 车辆状态拉取间隔（秒）· 按行驶中 / 白天 09:00–17:00 / 夜间 17:01–08:59 自动选择
NIO_VEHICLE_POLL_DRIVING_SEC=900
NIO_VEHICLE_POLL_DAY_SEC=1800
NIO_VEHICLE_POLL_NIGHT_SEC=3600

# 签到 API（GET）· 每天 9:00 拉取一次，9 点后首次打开补拉
NIO_CHECKIN_API_URL=https://gateway-front-external.nio.com/moat/10086//n/c/award/square?event=checkin&collection_id=1843940587332317185
NIO_CHECKIN_ACCESS_TOKEN=

# 菜单栏显示项（逗号分隔）：soc,range,actual_range,vehicle_state,mileage,orders
NIO_TRAY_DISPLAY=soc,range

# 兼容旧配置（换电未单独配置时回退）
NIO_POLL_INTERVAL=3600
WEB_PORT=8088

# ============================================================
# 换电 / 服务订单接口
# ============================================================
# 从 Postman 复制完整 URL（Query Params），再单独填 Token；请求方式为 POST
NIO_CHANGE_API_URL=https://gateway-front-external.nio.com/moat/1100367/api/v1/otd/car/ext/general/serviceOrder/getTabOrder?offset=0&limit=2000&orderTypes=pe_shaman,pe_shaman_change,service_pe_discharge,battery_flexible_upgrade,nsom_so_maintenance,nsom_so_chauffeur,chauffeur_vehicle_delivery,so_case_accident
NIO_CHANGE_ACCESS_TOKEN=
NIO_CHANGE_POLL_INTERVAL=3600

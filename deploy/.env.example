# ============================================================
# 车辆信息接口（独立配置）
# ============================================================
# 方式 A：Widget 参数模式（推荐）
NIO_VEHICLE_API_MODE=widget
NIO_VEHICLE_API_METHOD=GET
NIO_VEHICLE_REGION=cn
NIO_VEHICLE_APP_ID=10002
NIO_VEHICLE_LANG=zh-CN
NIO_VEHICLE_ID=your_vehicle_id
NIO_VEHICLE_APP_VER=6.5.3
NIO_VEHICLE_DEVICE_ID=your_device_id
NIO_VEHICLE_WIDGET_FUNCTIONS=rvs_run_frequent_appointment,rvs_set_defender_mode,rvs_rpa_out,rvs_exe_findme
NIO_VEHICLE_WIDGET_SIZE=medium
NIO_VEHICLE_API_TIMESTAMP=
NIO_VEHICLE_API_SIGN=
NIO_VEHICLE_ACCESS_TOKEN=
# NIO_VEHICLE_USER_AGENT=VehicleWidgetExtension/6.5.3 ...
# NIO_VEHICLE_COOKIE=tgw_l7_route=...

# 方式 B：完整 URL（与 Postman 完整复制一致）
# NIO_VEHICLE_API_MODE=
# NIO_VEHICLE_API_URL=https://app.nio.com/app/api/icar/v2/widget/info?...
# NIO_VEHICLE_API_HEADERS={"Authorization":"Bearer xxx","User-Agent":"VehicleWidgetExtension/6.5.3 ..."}
# NIO_VEHICLE_API_BODY=

# 车辆状态拉取间隔（秒）· 按行驶中 / 白天 09:00–17:00 / 夜间 17:01–08:59 自动选择
NIO_VEHICLE_POLL_DRIVING_SEC=900
NIO_VEHICLE_POLL_DAY_SEC=1800
NIO_VEHICLE_POLL_NIGHT_SEC=3600

# 兼容旧配置（换电未单独配置时回退）
NIO_POLL_INTERVAL=3600
WEB_PORT=8088

# ============================================================
# 换电记录接口（独立配置 · POST + Query Params）
# ============================================================
NIO_CHANGE_API_MODE=params
NIO_CHANGE_API_METHOD=POST
NIO_CHANGE_HASH_TYPE=sha256
NIO_CHANGE_LANG=zh
NIO_CHANGE_REGION=US
NIO_CHANGE_TZ_OFFSET=28800
NIO_CHANGE_NIO_APP_VERSION=6.5.3
NIO_CHANGE_APP_VERSION=5.31.0
NIO_CHANGE_ORDER_CONF_VERSION=5.31.0
NIO_CHANGE_APP_VER=6.5.3
NIO_CHANGE_OFFSET=0
NIO_CHANGE_LIMIT=200
# pe_shaman,pe_shaman_change,service_pe_discharge,battery_flexible_upgrade,...
NIO_CHANGE_ORDER_TYPES=pe_shaman,pe_shaman_change,service_pe_discharge,battery_flexible_upgrade,nsom_so_maintenance,nsom_so_chauffeur,chauffeur_vehicle_delivery,so_case_accident
NIO_CHANGE_IN_PROGRESS_STATUS=false
NIO_CHANGE_PAGINATION_METHOD=2
NIO_CHANGE_ACCESS_TOKEN=
NIO_CHANGE_COOKIE=
# NIO_CHANGE_USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 18_7 ...
# NIO_CHANGE_MOBILEINFO={"deviceModel":"iPhone14,2",...}
NIO_CHANGE_ACCEPT=application/json, text/plain, */*
NIO_CHANGE_ACCEPT_ENCODING=gzip, deflate, br, zstd
NIO_CHANGE_ACCEPT_LANGUAGE=zh-CN,zh-Hans;q=0.9
NIO_CHANGE_CONTENT_TYPE=application/json
NIO_CHANGE_CONNECTION=keep-alive
NIO_CHANGE_ORIGIN=null
NIO_CHANGE_PRIORITY=u=3, i
NIO_CHANGE_SEC_FETCH_DEST=empty
NIO_CHANGE_SEC_FETCH_MODE=cors
NIO_CHANGE_SEC_FETCH_SITE=cross-site
# 换电/服务订单拉取间隔（秒）
NIO_CHANGE_POLL_INTERVAL=3600
